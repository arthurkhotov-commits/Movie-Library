import tkinter as tk
from tkinter import messagebox, ttk
import random
import json
import os

# Предопределённые задачи
PREDEFINED_TASKS = [
    {"description": "Прочитать статью по Python", "type": "учёба"},
    {"description": "Сделать зарядку 15 минут", "type": "спорт"},
    {"description": "Написать отчёт по работе", "type": "работа"},
    {"description": "Изучить новый фреймворк", "type": "учёба"},
    {"description": "Пробежка на улице", "type": "спорт"},
    {"description": "Созвониться с клиентом", "type": "работа"},
]

HISTORY_FILE = "tasks_history.json"

class RandomTaskGenerator:
    def __init__(self, root):
        self.root = root
        self.root.title("Random Task Generator")
        self.root.geometry("500x500")

        # Загрузка истории
        self.history = self.load_history()

        # Переменные
        self.filter_var = tk.StringVar(value="все")
        self.new_task_var = tk.StringVar()

        # UI
        self.create_widgets()
        self.update_task_list()

    def create_widgets(self):
        # Верхняя панель: генерация
        gen_frame = tk.Frame(self.root)
        gen_frame.pack(pady=10)

        self.task_label = tk.Label(gen_frame, text="Нажмите кнопку", font=("Arial", 12), wraplength=400)
        self.task_label.pack(pady=5)

        tk.Button(gen_frame, text="🎲 Сгенерировать задачу", command=self.generate_task, bg="lightblue").pack(pady=5)

        # Фильтр
        filter_frame = tk.Frame(self.root)
        filter_frame.pack(pady=5)

        tk.Label(filter_frame, text="Фильтр по типу:").pack(side=tk.LEFT, padx=5)
        filter_combo = ttk.Combobox(filter_frame, textvariable=self.filter_var, values=["все", "учёба", "спорт", "работа"], state="readonly")
        filter_combo.pack(side=tk.LEFT, padx=5)
        tk.Button(filter_frame, text="Применить фильтр", command=self.update_task_list).pack(side=tk.LEFT, padx=5)

        # Список истории
        self.task_listbox = tk.Listbox(self.root, height=12, font=("Arial", 10))
        self.task_listbox.pack(fill=tk.BOTH, expand=True, padx=10, pady=5)

        # Добавление новой задачи
        add_frame = tk.Frame(self.root)
        add_frame.pack(pady=10, fill=tk.X, padx=10)

        tk.Label(add_frame, text="Новая задача:").pack(side=tk.LEFT)
        tk.Entry(add_frame, textvariable=self.new_task_var, width=30).pack(side=tk.LEFT, padx=5)
        type_combo = ttk.Combobox(add_frame, values=["учёба", "спорт", "работа"], state="readonly", width=10)
        type_combo.pack(side=tk.LEFT, padx=5)
        type_combo.current(0)

        def add_task():
            desc = self.new_task_var.get().strip()
            task_type = type_combo.get()
            if not desc:
                messagebox.showwarning("Ошибка", "Описание задачи не может быть пустым!")
                return
            if task_type not in ["учёба", "спорт", "работа"]:
                messagebox.showwarning("Ошибка", "Выберите корректный тип задачи")
                return

            self.history.append({"description": desc, "type": task_type})
            self.save_history()
            self.update_task_list()
            self.new_task_var.set("")

        tk.Button(add_frame, text="➕ Добавить задачу", command=add_task, bg="lightgreen").pack(side=tk.LEFT, padx=5)

        # Кнопка очистки истории
        tk.Button(self.root, text="🗑 Очистить историю", command=self.clear_history, fg="red").pack(pady=10)

    def generate_task(self):
        # Выбираем случайную задачу из предопределённого списка + пользовательских
        all_tasks = PREDEFINED_TASKS + self.history
        if not all_tasks:
            messagebox.showinfo("Нет задач", "Добавьте хотя бы одну задачу вручную или перезапустите программу")
            return

        task = random.choice(all_tasks)
        self.task_label.config(text=f"✅ {task['description']} [{task['type']}]")

        # Сохраняем в историю (можно дублировать, но по желанию — сохраним каждую сгенерированную)
        self.history.append(task.copy())
        self.save_history()
        self.update_task_list()

    def update_task_list(self):
        self.task_listbox.delete(0, tk.END)
        filter_type = self.filter_var.get()
        for i, task in enumerate(self.history, 1):
            if filter_type == "все" or task["type"] == filter_type:
                self.task_listbox.insert(tk.END, f"{i}. {task['description']} [{task['type']}]")

    def save_history(self):
        with open(HISTORY_FILE, "w", encoding="utf-8") as f:
            json.dump(self.history, f, ensure_ascii=False, indent=2)

    def load_history(self):
        if os.path.exists(HISTORY_FILE):
            with open(HISTORY_FILE, "r", encoding="utf-8") as f:
                try:
                    return json.load(f)
                except:
                    return []
        return []

    def clear_history(self):
        if messagebox.askyesno("Очистка", "Вы уверены, что хотите удалить всю историю?"):
            self.history.clear()
            self.save_history()
            self.update_task_list()
            self.task_label.config(text="История очищена")

if __name__ == "__main__":
    root = tk.Tk()
    app = RandomTaskGenerator(root)
    root.mainloop()
