import tkinter as tk
from tkinter import messagebox, ttk
import random
import json
import os

# Предопределённые цитаты
PREDEFINED_QUOTES = [
    {"text": "Будь изменением, которое ты хочешь увидеть в мире.", "author": "Махатма Ганди", "theme": "мотивация"},
    {"text": "Я мыслю, следовательно, существую.", "author": "Рене Декарт", "theme": "философия"},
    {"text": "Единственный способ делать великую работу — любить то, что ты делаешь.", "author": "Стив Джобс", "theme": "мотивация"},
    {"text": "Жизнь — это то, что с тобой происходит, пока ты строишь планы.", "author": "Джон Леннон", "theme": "жизнь"},
    {"text": "Воображение важнее знания.", "author": "Альберт Эйнштейн", "theme": "творчество"},
    {"text": "Тьма не может изгнать тьму: только свет может это сделать.", "author": "Мартин Лютер Кинг", "theme": "философия"},
    {"text": "Успех — это способность идти от неудачи к неудаче, не теряя энтузиазма.", "author": "Уинстон Черчилль", "theme": "успех"},
    {"text": "Лучший способ предсказать будущее — изобрести его.", "author": "Алан Кей", "theme": "творчество"},
    {"text": "Наши сомнения — это предатели, которые заставляют нас терять то, что мы могли бы выиграть.", "author": "Уильям Шекспир", "theme": "мотивация"},
    {"text": "Сложнее всего начать действовать, остальное зависит от упорства.", "author": "Пауло Коэльо", "theme": "успех"},
]

HISTORY_FILE = "quotes_history.json"

class RandomQuoteGenerator:
    def __init__(self, root):
        self.root = root
        self.root.title("Random Quote Generator")
        self.root.geometry("650x600")
        self.root.resizable(True, True)

        # Загрузка истории
        self.history = self.load_history()
        
        # Загрузка пользовательских цитат
        self.user_quotes = self.load_user_quotes()

        # Переменные для фильтров
        self.filter_author_var = tk.StringVar(value="все авторы")
        self.filter_theme_var = tk.StringVar(value="все темы")

        # Переменные для добавления цитат
        self.new_quote_text = tk.StringVar()
        self.new_quote_author = tk.StringVar()
        self.new_quote_theme = tk.StringVar()

        # Создание интерфейса
        self.create_widgets()
        self.update_quote_list()
        self.update_filter_options()

    def create_widgets(self):
        # Заголовок
        title_label = tk.Label(self.root, text="📖 Random Quote Generator", font=("Arial", 16, "bold"))
        title_label.pack(pady=10)

        # Панель генерации
        gen_frame = tk.Frame(self.root)
        gen_frame.pack(pady=10)

        self.current_quote_label = tk.Label(gen_frame, text="Нажмите кнопку, чтобы получить цитату", 
                                            font=("Arial", 11, "italic"), wraplength=600, justify="center")
        self.current_quote_label.pack(pady=5)

        self.generate_btn = tk.Button(gen_frame, text="🎲 Сгенерировать цитату", command=self.generate_quote,
                                      bg="lightblue", font=("Arial", 11), width=25)
        self.generate_btn.pack(pady=10)

        # Панель фильтрации
        filter_frame = tk.LabelFrame(self.root, text="Фильтрация истории", font=("Arial", 10, "bold"))
        filter_frame.pack(pady=10, padx=10, fill=tk.X)

        # Фильтр по автору
        author_filter_frame = tk.Frame(filter_frame)
        author_filter_frame.pack(pady=5, padx=10, fill=tk.X)
        
        tk.Label(author_filter_frame, text="По автору:").pack(side=tk.LEFT, padx=5)
        self.author_filter_combo = ttk.Combobox(author_filter_frame, textvariable=self.filter_author_var, 
                                                state="readonly", width=30)
        self.author_filter_combo.pack(side=tk.LEFT, padx=5)
        self.author_filter_combo.bind("<<ComboboxSelected>>", lambda e: self.update_quote_list())

        # Фильтр по теме
        theme_filter_frame = tk.Frame(filter_frame)
        theme_filter_frame.pack(pady=5, padx=10, fill=tk.X)
        
        tk.Label(theme_filter_frame, text="По теме:").pack(side=tk.LEFT, padx=5)
        self.theme_filter_combo = ttk.Combobox(theme_filter_frame, textvariable=self.filter_theme_var,
                                               state="readonly", width=30)
        self.theme_filter_combo.pack(side=tk.LEFT, padx=5)
        self.theme_filter_combo.bind("<<ComboboxSelected>>", lambda e: self.update_quote_list())

        # Кнопка сброса фильтров
        tk.Button(filter_frame, text="Сбросить фильтры", command=self.reset_filters, 
                 bg="lightgray", width=15).pack(pady=5)

        # Список истории
        history_frame = tk.LabelFrame(self.root, text="История цитат", font=("Arial", 10, "bold"))
        history_frame.pack(pady=10, padx=10, fill=tk.BOTH, expand=True)

        scrollbar = tk.Scrollbar(history_frame)
        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)

        self.quote_listbox = tk.Listbox(history_frame, yscrollcommand=scrollbar.set, 
                                        font=("Arial", 10), height=12)
        self.quote_listbox.pack(side=tk.LEFT, fill=tk.BOTH, expand=True, padx=5, pady=5)
        scrollbar.config(command=self.quote_listbox.yview)

        # Панель добавления новой цитаты
        add_frame = tk.LabelFrame(self.root, text="Добавить новую цитату", font=("Arial", 10, "bold"))
        add_frame.pack(pady=10, padx=10, fill=tk.X)

        # Текст цитаты
        tk.Label(add_frame, text="Текст цитаты:").grid(row=0, column=0, sticky=tk.W, padx=5, pady=5)
        tk.Entry(add_frame, textvariable=self.new_quote_text, width=60).grid(row=0, column=1, padx=5, pady=5, columnspan=2)

        # Автор
        tk.Label(add_frame, text="Автор:").grid(row=1, column=0, sticky=tk.W, padx=5, pady=5)
        tk.Entry(add_frame, textvariable=self.new_quote_author, width=30).grid(row=1, column=1, padx=5, pady=5)

        # Тема
        tk.Label(add_frame, text="Тема:").grid(row=1, column=2, sticky=tk.W, padx=5, pady=5)
        theme_combo = ttk.Combobox(add_frame, textvariable=self.new_quote_theme, 
                                   values=["мотивация", "философия", "жизнь", "творчество", "успех", "другое"],
                                   state="readonly", width=20)
        theme_combo.grid(row=1, column=3, padx=5, pady=5)
        theme_combo.current(0)

        # Кнопка добавления
        tk.Button(add_frame, text="➕ Добавить цитату", command=self.add_quote, 
                 bg="lightgreen", font=("Arial", 10), width=20).grid(row=2, column=0, columnspan=4, pady=10)

        # Кнопка очистки истории
        self.clear_btn = tk.Button(self.root, text="🗑 Очистить историю", command=self.clear_history,
                                   fg="red", font=("Arial", 10), width=20)
        self.clear_btn.pack(pady=10)

    def get_all_quotes(self):
        """Возвращает все доступные цитаты (предопределённые + пользовательские)"""
        return PREDEFINED_QUOTES + self.user_quotes

    def generate_quote(self):
        """Генерирует случайную цитату"""
        all_quotes = self.get_all_quotes()
        
        if not all_quotes:
            messagebox.showinfo("Нет цитат", "Нет доступных цитат. Добавьте хотя бы одну цитату!")
            return

        quote = random.choice(all_quotes)
        
        # Отображаем цитату
        display_text = f"«{quote['text']}»\n\n— {quote['author']} (Тема: {quote['theme']})"
        self.current_quote_label.config(text=display_text)

        # Сохраняем в историю
        self.history.append(quote.copy())
        self.save_history()
        self.update_quote_list()

    def update_quote_list(self):
        """Обновляет список истории с учётом фильтров"""
        self.quote_listbox.delete(0, tk.END)
        
        author_filter = self.filter_author_var.get()
        theme_filter = self.filter_theme_var.get()
        
        for i, quote in enumerate(self.history, 1):
            # Применяем фильтры
            if author_filter != "все авторы" and quote["author"] != author_filter:
                continue
            if theme_filter != "все темы" and quote["theme"] != theme_filter:
                continue
            
            display_text = f"{i}. «{quote['text'][:60]}...» — {quote['author']} [{quote['theme']}]"
            self.quote_listbox.insert(tk.END, display_text)

    def update_filter_options(self):
        """Обновляет доступные варианты в фильтрах на основе истории"""
        all_quotes = self.get_all_quotes()
        
        # Собираем уникальных авторов
        authors = sorted(set(quote["author"] for quote in all_quotes))
        authors.insert(0, "все авторы")
        self.author_filter_combo['values'] = authors
        
        # Собираем уникальные темы
        themes = sorted(set(quote["theme"] for quote in all_quotes))
        themes.insert(0, "все темы")
        self.theme_filter_combo['values'] = themes

    def reset_filters(self):
        """Сбрасывает все фильтры"""
        self.filter_author_var.set("все авторы")
        self.filter_theme_var.set("все темы")
        self.update_quote_list()

    def add_quote(self):
        """Добавляет новую цитату от пользователя с проверкой"""
        text = self.new_quote_text.get().strip()
        author = self.new_quote_author.get().strip()
        theme = self.new_quote_theme.get().strip()

        # Валидация
        if not text:
            messagebox.showwarning("Ошибка", "Текст цитаты не может быть пустым!")
            return
        
        if not author:
            messagebox.showwarning("Ошибка", "Имя автора не может быть пустым!")
            return
        
        if not theme or theme == "другое":
            # Если тема "другое", запрашиваем ввод пользователя
            custom_theme = tk.simpledialog.askstring("Тема", "Введите название темы:")
            if not custom_theme:
                messagebox.showwarning("Ошибка", "Тема не может быть пустой!")
                return
            theme = custom_theme.strip()

        # Создаём новую цитату
        new_quote = {
            "text": text,
            "author": author,
            "theme": theme
        }

        # Добавляем в пользовательские цитаты
        self.user_quotes.append(new_quote)
        self.save_user_quotes()
        
        # Обновляем фильтры
        self.update_filter_options()
        
        # Очищаем поля ввода
        self.new_quote_text.set("")
        self.new_quote_author.set("")
        self.new_quote_theme.set("мотивация")
        
        messagebox.showinfo("Успех", "Цитата успешно добавлена!")

    def save_history(self):
        """Сохраняет историю в JSON файл"""
        with open(HISTORY_FILE, "w", encoding="utf-8") as f:
            json.dump(self.history, f, ensure_ascii=False, indent=2)

    def load_history(self):
        """Загружает историю из JSON файла"""
        if os.path.exists(HISTORY_FILE):
            with open(HISTORY_FILE, "r", encoding="utf-8") as f:
                try:
                    data = json.load(f)
                    if isinstance(data, list):
                        return data
                except:
                    pass
        return []

    def save_user_quotes(self):
        """Сохраняет пользовательские цитаты"""
        with open("user_quotes.json", "w", encoding="utf-8") as f:
            json.dump(self.user_quotes, f, ensure_ascii=False, indent=2)

    def load_user_quotes(self):
        """Загружает пользовательские цитаты"""
        if os.path.exists("user_quotes.json"):
            with open("user_quotes.json", "r", encoding="utf-8") as f:
                try:
                    data = json.load(f)
                    if isinstance(data, list):
                        return data
                except:
                    pass
        return []

    def clear_history(self):
        """Очищает историю с подтверждением"""
        if messagebox.askyesno("Очистка истории", "Вы уверены, что хотите удалить всю историю цитат?"):
            self.history.clear()
            self.save_history()
            self.update_quote_list()
            self.current_quote_label.config(text="История очищена")
            messagebox.showinfo("Успех", "История успешно очищена!")

if __name__ == "__main__":
    root = tk.Tk()
    app = RandomQuoteGenerator(root)
    
    # Центрируем окно на экране
    root.update_idletasks()
    width = root.winfo_width()
    height = root.winfo_height()
    x = (root.winfo_screenwidth() // 2) - (width // 2)
    y = (root.winfo_screenheight() // 2) - (height // 2)
    root.geometry(f'{width}x{height}+{x}+{y}')
    
    root.mainloop()
