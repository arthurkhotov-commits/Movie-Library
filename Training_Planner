    def reset_filters(self):
        """Сброс всех фильтров"""
        self.filter_type_var.set("Все типы")
        self.filter_month_var.set("Все месяцы")
        self.update_workouts_list()
        self.status_bar.config(text="🔄 Фильтры сброшены")
    
    def update_statistics(self):
        """Обновление статистики"""
        total = len(self.workouts)
        total_duration = sum(w["duration"] for w in self.workouts)
        avg_duration = total_duration // total if total > 0 else 0
        
        self.total_workouts_label.config(text=f"Всего тренировок: {total}")
        self.total_duration_label.config(text=f"Общая длительность: {total_duration} мин")
        self.avg_duration_label.config(text=f"Средняя длительность: {avg_duration} мин")
    
    def save_workouts(self):
        """Сохранение тренировок в JSON"""
        with open("workouts.json", "w", encoding="utf-8") as f:
            json.dump(self.workouts, f, ensure_ascii=False, indent=2)
    
    def load_workouts(self):
        """Загрузка тренировок из JSON"""
        if os.path.exists("workouts.json"):
            with open("workouts.json", "r", encoding="utf-8") as f:
                try:
                    data = json.load(f)
                    if isinstance(data, list):
                        return data
                except:
                    return []
        return []

