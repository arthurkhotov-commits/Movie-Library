    def add_workout(self):
        """Добавление новой тренировки с валидацией"""
        # Получаем данные
        date = self.date_var.get().strip()
        workout_type = self.type_var.get()
        duration = self.duration_var.get().strip()
        notes = self.notes_var.get().strip()
        
        # Валидация
        if not date:
            messagebox.showwarning("Ошибка", "Пожалуйста, укажите дату!")
            return
        
        # Проверка формата даты
        if not self.validate_date(date):
            messagebox.showwarning("Ошибка", "Неверный формат даты!\nИспользуйте: ГГГГ-ММ-ДД\nПример: 2026-04-28")
            return
        
        if not workout_type:
            messagebox.showwarning("Ошибка", "Пожалуйста, выберите тип тренировки!")
            return
        
        if not duration:
            messagebox.showwarning("Ошибка", "Пожалуйста, укажите длительность!")
            return
        
        # Проверка длительности (положительное число)
        try:
            duration_int = int(duration)
            if duration_int <= 0:
                messagebox.showwarning("Ошибка", "Длительность должна быть положительным числом!")
                return
            if duration_int > 1440:
                messagebox.showwarning("Ошибка", "Длительность не может превышать 1440 минут (24 часа)!")
                return
        except ValueError:
            messagebox.showwarning("Ошибка", "Длительность должна быть целым числом!")
            return
        
        # Создаём запись
        workout = {
            "date": date,
            "type": workout_type,
            "duration": duration_int,
            "notes": notes
        }
        
        # Добавляем в список
        self.workouts.append(workout)
        
        # Сортируем по дате
        self.workouts.sort(key=lambda x: x["date"])
        
        # Сохраняем и обновляем
        self.save_workouts()
        self.update_workouts_list()
        self.update_statistics()
        
        # Очищаем форму
        self.date_var.set("")
        self.type_var.set("")
        self.duration_var.set("")
        self.notes_var.set("")
        
        self.status_bar.config(text=f"✅ Тренировка добавлена: {date} - {workout_type} - {duration} мин")
    
    def validate_date(self, date_str):
        """Проверка формата даты"""
        pattern = r'^\d{4}-\d{2}-\d{2}$'
        if not re.match(pattern, date_str):
            return False
        
        try:
            datetime.strptime(date_str, "%Y-%m-%d")
            return True
        except ValueError:
            return False
    
    def delete_workout(self):
        """Удаление выбранной тренировки"""
        selection = self.tree.selection()
        if not selection:
            messagebox.showwarning("Ошибка", "Выберите тренировку для удаления!")
            return
        
        # Получаем индекс
        item = selection[0]
        index = int(self.tree.item(item)['values'][0])  # Сохраняем индекс в values
        
        # Находим реальный индекс в списке
        filtered_workouts = self.get_filtered_workouts()
        workout_to_delete = filtered_workouts[index]
        
        # Удаляем из списка
        self.workouts.remove(workout_to_delete)
        
        # Сохраняем и обновляем
        self.save_workouts()
        self.update_workouts_list()
        self.update_statistics()
        
        self.status_bar.config(text=f"❌ Тренировка удалена: {workout_to_delete['date']}")
    
    def get_filtered_workouts(self):
        """Получение отфильтрованного списка тренировок"""
        filtered = self.workouts.copy()
        
        # Фильтр по типу
        filter_type = self.filter_type_var.get()
        if filter_type != "Все типы":
            filtered = [w for w in filtered if w["type"] == filter_type]
        
        # Фильтр по месяцу
        filter_month = self.filter_month_var.get()
        if filter_month != "Все месяцы":
            month_num = self.months.index(filter_month)
            filtered = [w for w in filtered if datetime.strptime(w["date"], "%Y-%m-%d").month == month_num]
        
        return filtered
    
    def update_workouts_list(self):
        """Обновление списка тренировок с учётом фильтров"""
        # Очищаем дерево
        for item in self.tree.get_children():
            self.tree.delete(item)
        
        # Получаем отфильтрованные тренировки
        filtered = self.get_filtered_workouts()
        
        # Добавляем в дерево
        for i, workout in enumerate(filtered):
            self.tree.insert("", tk.END, values=(
                i,  # Временный индекс
                workout["date"],
                workout["type"],
                f"{workout['duration']} мин",
                workout["notes"][:30] + ("..." if len(workout["notes"]) > 30 else "")
            ))
        
        # Обновляем статус
        self.status_bar.config(text=f"📋 Показано тренировок: {len(filtered)} из {len(self.workouts)}")
    
